PORT=5000
# Listen on all interfaces (matches MongoDB Atlas IP access 0.0.0.0/0 for remote clients). Use 127.0.0.1 to restrict to this machine only.
HOST=0.0.0.0
# WHM Application Manager: set environment to Production and uncomment (recommended):
# NODE_ENV=production
# If /admin 404s on the live domain, either set NODE_ENV=production, or rely on Passenger auto-detect
# in server.js, or set SERVE_FRONTEND=1. Set SERVE_FRONTEND=0 only to disable SPA from this app.
# SERVE_FRONTEND=1
# Optional: absolute path to Vite outDir if not at repo_root/frontend/dist (WHM custom layout).
# STATIC_DIR=/home/user/Vercom_Solutions/frontend/dist
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority&appName=MyApp
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vercom_solutions?retryWrites=true&w=majority
# Optional if DATABASE is already in the URI path
# MONGODB_DB_NAME=
# Browser origin(s) allowed by CORS (no trailing slash). Production example:
# CLIENT_URL=https://vercomsolutions.in,https://www.vercomsolutions.in
# Local dev:
CLIENT_URL=http://localhost:5173
# Strong secret for /admin dashboard (header x-admin-key). Change in production.
ADMIN_SECRET=replace-with-long-random-secret
# Signing key for JWTs (use in code with jsonwebtoken / jose). Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-long-random-secret-min-32-chars
